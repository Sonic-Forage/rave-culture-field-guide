# Sonic-Forage framework local config example
# Copy to .env locally if needed. Never commit real .env values.

COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_ENABLE_PROMPT=false
COMFYUI_WORKFLOW_REGISTRY=framework/workflows/workflow-registry.json

VOICE_TTS_BASE_URL=http://127.0.0.1:7860
VOICE_TTS_BACKEND=local_or_omnivoice
VOICE_TTS_ENABLE_GENERATION=false
VOICE_TTS_VOICE=synthetic_host

REALTIME_ROUTER_ENABLE_MIC=false
REALTIME_ROUTER_ENABLE_WEBSOCKET=false
REALTIME_ROUTER_ENABLE_OSC=false
REALTIME_ROUTER_ENABLE_SHELL=false
REALTIME_ROUTER_BASE_URL=http://127.0.0.1:8787
REALTIME_ROUTER_WS_URL=ws://127.0.0.1:8787/ws/audio
REALTIME_ROUTER_LEDGER_PATH=logs/realtime-command-router-ledger.jsonl

PUBLIC_POSTING_APPROVED=false
VIDEO_UPLOAD_APPROVED=false
OUTREACH_APPROVED=false
PAYMENT_LINK_APPROVED=false
GPU_VIDEO_PRIVATE_MEDIA_APPROVED=false
